    @get
    func dec128ToIntegerFloorG(raw: uint256): uint128 {
        const d = dec128FromRaw(raw)
        return dec128ToIntegerFloor(d)
    }

    @get
    func dec128ToIntegerCeilG(raw: uint256): uint128 {
        const d = dec128FromRaw(raw)
