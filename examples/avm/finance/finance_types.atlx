    @get
    func dec128FractionalPartG(raw: uint256): uint128 {
        const d = dec128FromRaw(raw)
        return dec128FractionalPart(d)
    }

    // Overflow-proof getter: constructs a Decimal128 whose raw value is
    // guaranteed to exceed uint128's range (2^128 through mulDiv's unbounded
    // intermediate), proving toUint128 TRAPS rather than silently wrapping.
    @get
    func dec128OverflowTrapG(hugeNumerator: uint256): Decimal128 {
        const r = ratioFromRaw(hugeNumerator, 1)
        return dec128FromRatioFloor(r)
    }

    // ---- SignedDecimal256 ----
    @get
    func sdec256FromIntG(n: int256): SignedDecimal256 {
        return sdec256FromInt(n)
    }

    @get
    func sdec256RawG(raw: int256): int256 {
        const d = sdec256FromRaw(raw)
        return sdec256Raw(d)
    }

    @get
    func sdec256FromRatioG(num: uint256, den: uint256): SignedDecimal256 {
        const r = ratioFromRaw(num, den)
        return sdec256FromRatio(r)
    }

    @get
    func sdec256FromBasisPointsG(bps: uint256): SignedDecimal256 {
        const bp = bpFromRaw(bps)
        return sdec256FromBasisPoints(bp)
    }

    @get
    func sdec256MulG(rawA: int256, rawB: int256): SignedDecimal256 {
        const a = sdec256FromRaw(rawA)
        const b = sdec256FromRaw(rawB)
        return sdec256Mul(a, b)
    }

    @get
    func sdec256DivG(rawA: int256, rawB: int256): SignedDecimal256 {
        const a = sdec256FromRaw(rawA)
        const b = sdec256FromRaw(rawB)
        return sdec256Div(a, b)
    }

    @get
    func sdec256ToIntegerG(raw: int256): int256 {
        const d = sdec256FromRaw(raw)
        return sdec256ToInteger(d)
    }

    @get
    func sdec256IntegerPartG(raw: int256): int256 {
        const d = sdec256FromRaw(raw)
        return sdec256IntegerPart(d)
    }

    @get
    func sdec256FractionalPartG(raw: int256): int256 {
        const d = sdec256FromRaw(raw)
        return sdec256FractionalPart(d)
    }

    // ---- SignedDecimal128 ----
    @get
    func sdec128FromIntG(n: int256): SignedDecimal128 {
        return sdec128FromInt(n)
    }

    @get
    func sdec128RawG(raw: int256): int128 {
        const d = sdec128FromRaw(raw)
        return sdec128Raw(d)
    }

    @get
    func sdec128MulG(rawA: int256, rawB: int256): SignedDecimal128 {
        const a = sdec128FromRaw(rawA)
        const b = sdec128FromRaw(rawB)
        return sdec128Mul(a, b)
    }

    @get
    func sdec128DivG(rawA: int256, rawB: int256): SignedDecimal128 {
        const a = sdec128FromRaw(rawA)
        const b = sdec128FromRaw(rawB)
        return sdec128Div(a, b)
    }

    @get
    func sdec128ToIntegerG(raw: int256): int128 {
        const d = sdec128FromRaw(raw)
        return sdec128ToInteger(d)
    }

    // Overflow-proof getter: a huge negative int256 raw value narrowed to
    // int128 must TRAP, not wrap — proves toInt128 checks the SIGNED range
    // (not just magnitude) too.
    @get
    func sdec128OverflowTrapG(hugeRaw: int256): SignedDecimal128 {
        return SignedDecimal128{raw: toInt128(hugeRaw)}
    }

    // ---- PnL / equity ----
    @get
    func pnlEquityOfG(entryPrice: int256, exitPrice: int256, size: int256): SignedDecimal256 {
        return pnlEquityOf(entryPrice, exitPrice, size)
    }

    @get
    func pnlEquityScaleG(rateRaw: int256, sizeRaw: int256): SignedDecimal256 {
        const rate = sdec256FromRaw(rateRaw)
        const size = sdec256FromRaw(sizeRaw)
        return pnlEquityScale(rate, size)
    }

    @get
    func pnlEquityTotalG(marginRaw: int256, pnlRaw: int256): SignedDecimal256 {
        const margin = sdec256FromRaw(marginRaw)
        const pnl = sdec256FromRaw(pnlRaw)
        return pnlEquityTotal(margin, pnl)
    }

    @get
    func pnlEquityIsNegativeG(entryPrice: int256, exitPrice: int256, size: int256): uint64 {
        const pnl = pnlEquityOf(entryPrice, exitPrice, size)
        return pnlEquityIsNegative(pnl)
    }
}
