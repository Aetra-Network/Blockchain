    @get
    func dec256DivFloorG(rawA: uint256, rawB: uint256): Decimal256 {
        const a = dec256FromRaw(rawA)
        const b = dec256FromRaw(rawB)
        return dec256DivFloor(a, b)
    }

    @get
    func dec256DivCeilG(rawA: uint256, rawB: uint256): Decimal256 {
        const a = dec256FromRaw(rawA)
        const b = dec256FromRaw(rawB)
        return dec256DivCeil(a, b)
    }

    @get
    func dec256DivNearestG(rawA: uint256, rawB: uint256): Decimal256 {
        const a = dec256FromRaw(rawA)
        const b = dec256FromRaw(rawB)
        return dec256DivNearest(a, b)
    }

    @get
    func dec256ToIntegerFloorG(raw: uint256): uint256 {
        const d = dec256FromRaw(raw)
        return dec256ToIntegerFloor(d)
    }

    @get
    func dec256ToIntegerCeilG(raw: uint256): uint256 {
        const d = dec256FromRaw(raw)
        return dec256ToIntegerCeil(d)
    }

    @get
    func dec256ToIntegerNearestG(raw: uint256): uint256 {
        const d = dec256FromRaw(raw)
        return dec256ToIntegerNearest(d)
    }

    @get
    func dec256IntegerPartG(raw: uint256): uint256 {
        const d = dec256FromRaw(raw)
        return dec256IntegerPart(d)
    }

    @get
    func dec256FractionalPartG(raw: uint256): uint256 {
        const d = dec256FromRaw(raw)
