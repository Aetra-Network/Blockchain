    // ---- Decimal128 ----
    @get
    func dec128FromIntG(n: uint256): Decimal128 {
        return dec128FromInt(n)
    }

    @get
    func dec128RawG(raw: uint256): uint128 {
        const d = dec128FromRaw(raw)
        return dec128Raw(d)
    }

    @get
    func dec128FromRatioFloorG(num: uint256, den: uint256): Decimal128 {
        const r = ratioFromRaw(num, den)
        return dec128FromRatioFloor(r)
    }

    @get
    func dec128FromRatioCeilG(num: uint256, den: uint256): Decimal128 {
        const r = ratioFromRaw(num, den)
        return dec128FromRatioCeil(r)
    }

    @get
    func dec128FromRatioNearestG(num: uint256, den: uint256): Decimal128 {
        const r = ratioFromRaw(num, den)
        return dec128FromRatioNearest(r)
    }

    @get
    func dec128FromBasisPointsG(bps: uint256): Decimal128 {
        const bp = bpFromRaw(bps)
        return dec128FromBasisPoints(bp)
    }

    @get
    func dec128MulFloorG(rawA: uint256, rawB: uint256): Decimal128 {
        const a = dec128FromRaw(rawA)
        const b = dec128FromRaw(rawB)
        return dec128MulFloor(a, b)
    }

    @get
    func dec128DivFloorG(rawA: uint256, rawB: uint256): Decimal128 {
        const a = dec128FromRaw(rawA)
        const b = dec128FromRaw(rawB)
